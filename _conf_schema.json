{
  "enabled": {
    "type": "bool",
    "description": "启用插件",
    "default": true
  },
  "jm_usernames": {
    "type": "list",
    "description": "JM 用户名池，建议与 jm_passwords 一一对应",
    "default": []
  },
  "jm_passwords": {
    "type": "list",
    "description": "JM 密码池，建议与 jm_usernames 一一对应",
    "default": []
  },
  "jm_domains": {
    "type": "list",
    "description": "JM 域名池",
    "default": []
  },
  "proxy_pool": {
    "type": "list",
    "description": "代理池",
    "default": []
  },
  "max_search_results": {
    "type": "int",
    "description": "搜索结果最大返回条数",
    "default": 5
  },
  "dependency_check_on_startup": {
    "type": "bool",
    "description": "启动时检查依赖",
    "default": true
  },
  "auto_install_dependencies": {
    "type": "bool",
    "description": "缺失依赖时自动安装",
    "default": true
  },
  "dependency_install_timeout_seconds": {
    "type": "int",
    "description": "依赖安装超时时间（秒）",
    "default": 300
  },
  "cache_enabled": {
    "type": "bool",
    "description": "启用缓存",
    "default": true
  },
  "cache_ttl_seconds": {
    "type": "int",
    "description": "缓存时间（秒）",
    "default": 300
  },
  "memory_enabled": {
    "type": "bool",
    "description": "启用会话上下文记忆",
    "default": true
  },
  "memory_ttl_seconds": {
    "type": "int",
    "description": "上下文记忆保留时长（秒）",
    "default": 3600
  },
  "nsfw_notice": {
    "type": "bool",
    "description": "返回结果前附加 NSFW 提示",
    "default": true
  },
  "download_root_dir": {
    "type": "string",
    "description": "下载根目录",
    "default": "data/downloads"
  },
  "download_zip_by_default": {
    "type": "bool",
    "description": "下载任务默认生成 zip",
    "default": false
  },
  "max_concurrent_downloads": {
    "type": "int",
    "description": "最大并发下载任务数",
    "default": 2
  },
  "download_retry_count": {
    "type": "int",
    "description": "下载重试次数",
    "default": 2
  },
  "download_timeout_seconds": {
    "type": "int",
    "description": "下载超时时间（秒）",
    "default": 60
  },
  "admin_only_download": {
    "type": "bool",
    "description": "仅管理员可下载/取消任务",
    "default": true
  },
  "admin_users": {
    "type": "list",
    "description": "管理员用户列表",
    "default": []
  },
  "comments_enabled": {
    "type": "bool",
    "description": "启用评论抓取",
    "default": true
  },
  "summary_enabled": {
    "type": "bool",
    "description": "启用内容/评论总结",
    "default": true
  },
  "sentiment_enabled": {
    "type": "bool",
    "description": "启用评论情感分析",
    "default": true
  },
  "recommend_enabled": {
    "type": "bool",
    "description": "启用相似作品推荐",
    "default": true
  },
  "recommend_max_results": {
    "type": "int",
    "description": "推荐结果最大数量",
    "default": 5
  },
  "workflow_enabled": {
    "type": "bool",
    "description": "启用多步工作流",
    "default": true
  },
  "llm_postprocess_enabled": {
    "type": "bool",
    "description": "启用 LLM 二次润色输出",
    "default": true
  },
  "llm_postprocess_max_chars": {
    "type": "int",
    "description": "LLM 二次润色最大输入长度",
    "default": 4000
  },
  "llm_persona_style_prompt": {
    "type": "string",
    "description": "LLM 人设风格附加提示词",
    "default": "请严格延续当前会话模型的人设、语气和表达风格。"
  }
}